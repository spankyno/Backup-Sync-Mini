# ==========================================
# BackupHub - Variables de entorno (ejemplo)
# Copia este archivo como .env y ajusta valores 
# ========================================== 

NODE_ENV=development

# --- API (NestJS) ---
API_PORT=4000
DATABASE_URL="postgresql://backuphub:backuphub@localhost:5432/backuphub?schema=public"
# En desarrollo local también puede usarse SQLite:
# DATABASE_URL="file:./dev.db"

JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-too"
JWT_REFRESH_EXPIRES_IN="7d"

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Orígenes permitidos para CORS (separados por comas). Sin esta variable
# solo se permite http://localhost:3000. En producción incluye el dominio
# público de la API (el mismo que expones vía Cloudflare Tunnel) y el/los
# dominios de la Web (Cloudflare Workers y/o custom domain), p.ej.:
# ALLOWED_ORIGINS="https://backuphub.example.com,https://backuphub-web.<tu-subdominio>.workers.dev"
ALLOWED_ORIGINS=""

# Token del túnel de Cloudflare que expone la API (apps/api) con TLS
# automático, sin abrir puertos en el servidor. Se genera al crear el
# túnel en el dashboard de Cloudflare Zero Trust > Networks > Tunnels.
# Ver docs/cloudflare-tunnel.md. Deja vacío si aún no usas Cloudflare.
TUNNEL_TOKEN=""

# --- Web (Next.js) ---
# En local: http://localhost:4000
# Desplegada en Cloudflare Workers: URL pública de la API en Docker/VPS
# (debe servir HTTPS/WSS, ver docker-compose.yml + un reverse proxy/dominio)
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"

# --- Agent (Rust) ---
AGENT_DEFAULT_PORT=3845
AGENT_TOKEN_SECRET="change-me-agent-secret"
AGENT_DB_PATH="./agent.db"
