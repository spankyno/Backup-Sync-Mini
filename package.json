{
  "name": "backuphub",
  "private": true,
  "version": "0.1.0",
  "description": "BackupHub - Plataforma web local-first para gestión de backups mediante agentes locales",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @backuphub/api prisma:generate",
    "db:migrate": "pnpm --filter @backuphub/api prisma:migrate",
    "agent:build": "pnpm --filter @backuphub/agent build",
    "agent:dev": "pnpm --filter @backuphub/agent dev",
    "web:cf:deploy": "pnpm --filter @backuphub/web cf:deploy"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
